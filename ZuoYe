<!DOCTYPE html>
<html lang="zh-CN">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>个人信息卡片页面</title>
    <style>
        /* --- CSS 样式部分 --- */
        
        /* 1. 全局重置与基础布局 */
        * {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
        }

        body {
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            background: linear-gradient(135deg, #f5f7fa 0%, #c3cfe2 100%); /* 渐变背景 */
            height: 100vh;
            display: flex;
            justify-content: center;
            align-items: center;
        }

        h1 {
            text-align: center;
            color: #333;
            margin-bottom: 20px;
            font-size: 1.8rem;
        }

        /* 2. 卡片容器样式 */
        .card-container {
            background: #fff;
            width: 350px;
            padding: 40px;
            border-radius: 20px;
            box-shadow: 0 10px 25px rgba(0,0,0,0.1); /* 阴影效果 */
            text-align: center;
            transition: transform 0.3s ease; /* 创新点：悬停动画 */
        }

        .card-container:hover {
            transform: translateY(-5px); /* 鼠标悬停时卡片上浮 */
        }

        /* 3. 头像样式 */
        .avatar {
            width: 120px;
            height: 120px;
            border-radius: 50%; /* 圆形头像 */
            object-fit: cover;
            border: 4px solid #e0e0e0;
            margin-bottom: 20px;
            cursor: pointer;
            transition: border-color 0.3s;
        }

        .avatar:hover {
            border-color: #4a90e2;
        }

        /* 隐藏文件上传输入框 */
        #avatar-upload {
            display: none;
        }

        /* 4. 表单输入框样式 */
        .input-group {
            margin-bottom: 15px;
            text-align: left;
        }

        label {
            display: block;
            margin-bottom: 5px;
            color: #666;
            font-size: 0.9rem;
            font-weight: bold;
        }

        input[type="text"], textarea {
            width: 100%;
            padding: 12px;
            border: 1px solid #ddd;
            border-radius: 8px;
            font-size: 1rem;
            outline: none;
            transition: border-color 0.3s, box-shadow 0.3s;
        }

        /* 输入框聚焦效果 */
        input[type="text"]:focus, textarea:focus {
            border-color: #4a90e2;
            box-shadow: 0 0 8px rgba(74, 144, 226, 0.2);
        }

        textarea {
            resize: vertical; /* 允许垂直拖拽调整大小 */
            min-height: 80px;
        }

        /* 5. 按钮样式 */
        .save-btn {
            background-color: #4a90e2;
            color: white;
            border: none;
            padding: 12px 30px;
            border-radius: 8px;
            font-size: 1rem;
            cursor: pointer;
            width: 100%;
            transition: background-color 0.3s;
        }

        .save-btn:hover {
            background-color: #357abd;
        }

        /* 6. 响应式适配 */
        @media (max-width: 400px) {
            .card-container {
                width: 90%;
                padding: 20px;
            }
        }
    </style>
</head>
<body>

    <div>
        <h1>个人信息卡片</h1>
        
        <div class="card-container">
            <!-- 头像区域 -->
            <!-- 使用默认头像占位 -->
            <img src="data:image/svg+xml;base64,PHN2ZyB4bWxucz0iaHR0cDovL3d3dy53My5vcmcvMjAwMC9zdmciIHZpZXdCb3g9IjAgMCAyNCAyNCIgZmlsbD0iI2NjYyI+PHBhdGggZD0iTTEyIDEyYzIuMjEgMCA0LTEuNzkgNC00cz0xLjc5LTQgNC00LTEuNzkgNC00IDQgMS43OSA0IDQgNHptMCAyYy0yLjY3IDAtOCAxLjM0LTggNHYyaDE2di0yYzAtMi42Ni01LjMzLTQtOC00eiIvPjwvc3ZnPg==" alt="个人头像" class="avatar" id="avatar-img">
            <!-- 隐藏的文件输入框 -->
            <input type="file" id="avatar-upload" accept="image/*">

            <!-- 表单区域 -->
            <form id="profile-form">
                <div class="input-group">
                    <label for="name">姓名</label>
                    <input type="text" id="name" placeholder="请输入你的姓名" value="张三">
                </div>
                
                <div class="input-group">
                    <label for="bio">个人简介</label>
                    <textarea id="bio" placeholder="介绍一下你自己...">热爱编程，喜欢探索新技术。</textarea>
                </div>

                <button type="submit" class="save-btn">保存修改</button>
            </form>
        </div>
    </div>

    <script>
        /* --- JavaScript 功能部分 --- */

        // 1. 获取 DOM 元素
        const avatarImg = document.getElementById('avatar-img');
        const avatarUpload = document.getElementById('avatar-upload');
        const form = document.getElementById('profile-form');
        const nameInput = document.getElementById('name');
        const bioInput = document.getElementById('bio');

        // 2. 头像上传功能
        // 点击头像触发隐藏的文件输入框
        avatarImg.addEventListener('click', () => {
            avatarUpload.click();
        });

        // 监听文件选择变化
        avatarUpload.addEventListener('change', function() {
            const file = this.files[0]; // 获取用户选择的文件
            
            if (file) {
                // 使用 FileReader 读取文件并预览
                const reader = new FileReader();
                
                reader.onload = function(e) {
                    avatarImg.src = e.target.result; // 将读取的图片数据赋值给 img 标签
                }
                
                reader.readAsDataURL(file); // 读取为 Data URL
            }
        });

        // 3. 保存功能
        form.addEventListener('submit', function(e) {
            e.preventDefault(); // 阻止表单默认的提交刷新行为

            const newName = nameInput.value;
            const newBio = bioInput.value;

            // 简单的反馈交互（创新点：这里可以用更复杂的 Toast 提示）
            if(newName && newBio) {
                alert(`保存成功！\n姓名：${newName}\n简介：${newBio}`);
                // 在实际项目中，这里通常会发送 AJAX 请求给后端
            } else {
                alert('请填写完整信息');
            }
        });
    </script>
</body>
</html>